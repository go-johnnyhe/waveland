---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<div class="mockup-wrap">
  <!-- Popover arrow -->
  <div class="popover-arrow" aria-hidden="true"></div>

  <!-- Popover body -->
  <div class="popover">
    <!-- Idle State -->
    <div class="state state-idle">
      <div class="pop-header">
        <div class="app-icon" aria-hidden="true">
          <img src={`${base}shadow-icon.png`} alt="" width="28" height="28" />
        </div>
        <div class="app-meta">
          <span class="app-title">Shadow</span>
          <span class="app-subtitle">Real-time file collaboration</span>
        </div>
      </div>

      <div class="pop-divider"></div>

      <div class="pop-actions">
        <button class="mac-btn mac-btn-blue start-btn" type="button" tabindex="-1">Start Session</button>
        <button class="mac-btn mac-btn-secondary" type="button" tabindex="-1">Join Session</button>
      </div>

      <label class="checkbox-row">
        <span class="checkbox-box checkbox-unchecked" aria-hidden="true"></span>
        <span class="checkbox-label">Read-only for joiners</span>
      </label>

      <div class="pop-divider"></div>

      <div class="pop-footer">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="lock-icon">
          <rect x="2" y="4.5" width="6" height="4.5" rx="1" fill="#6b7280"/>
          <path d="M3.5 4.5V3C3.5 1.62 4.34 1 5 1C5.66 1 6.5 1.62 6.5 3V4.5" stroke="#6b7280" stroke-width="1" fill="none" stroke-linecap="round"/>
        </svg>
        <span>End-to-end encrypted</span>
      </div>
    </div>

  </div>

  <!-- Ambient glow -->
  <div class="mockup-glow" aria-hidden="true"></div>
</div>

<style>
  .mockup-wrap {
    position: relative;
    width: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  /* ---- Popover Arrow ---- */
  .popover-arrow {
    width: 16px;
    height: 8px;
    position: relative;
    right: -100px;
    clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
    background: rgba(30, 30, 30, 0.85);
  }

  /* ---- Popover Body ---- */
  .popover {
    position: relative;
    width: 280px;
    background: rgba(30, 30, 30, 0.85);
    backdrop-filter: blur(20px) saturate(1.5);
    -webkit-backdrop-filter: blur(20px) saturate(1.5);
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.55),
      0 0 1px rgba(255, 255, 255, 0.1) inset;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .state {
    padding: 14px;
  }

  /* ---- Shared Elements ---- */
  .pop-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .app-icon {
    flex-shrink: 0;
  }

  .app-icon img {
    border-radius: 6px;
    display: block;
  }

  .app-meta {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .app-title {
    font-size: 13px;
    font-weight: 600;
    color: #f0f0f0;
    letter-spacing: -0.01em;
  }

  .app-subtitle {
    font-size: 11px;
    color: #8e8e93;
    letter-spacing: -0.01em;
  }

  .pop-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: 0 -14px;
    margin-bottom: 12px;
  }

  /* ---- macOS Buttons ---- */
  .mac-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 28px;
    padding: 0 14px;
    border-radius: 6px;
    font-size: 12.5px;
    font-weight: 500;
    font-family: inherit;
    letter-spacing: -0.01em;
    cursor: default;
    border: none;
    transition: filter 0.15s ease;
    white-space: nowrap;
  }

  .mac-btn-blue {
    background: #0A84FF;
    color: #fff;
  }

  .mac-btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #f0f0f0;
    border: 0.5px solid rgba(255, 255, 255, 0.15);
  }

  /* ---- Idle-State Layout ---- */
  .pop-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 12px;
  }

  .checkbox-row {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-bottom: 12px;
    cursor: default;
  }

  .checkbox-box {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    background: #0A84FF;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .checkbox-unchecked {
    background: transparent;
    border: 1.5px solid rgba(255, 255, 255, 0.25);
  }

  .checkbox-label {
    font-size: 11.5px;
    color: #d1d1d6;
    letter-spacing: -0.01em;
  }

  .pop-footer {
    display: flex;
    align-items: center;
    gap: 5px;
    padding-top: 0;
  }

  .pop-footer span {
    font-size: 10.5px;
    color: #636366;
    letter-spacing: -0.01em;
  }

  .lock-icon {
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* ---- Ambient Glow ---- */
  .mockup-glow {
    position: absolute;
    width: 200px;
    height: 200px;
    bottom: -40px;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(34, 211, 170, 0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .mockup-wrap {
      transform: scale(0.92);
      transform-origin: top center;
    }
  }

  @media (max-width: 640px) {
    .mockup-wrap {
      transform: scale(0.85);
      transform-origin: top center;
    }
  }
</style>
