---
import { githubUrl, marketplaceUrl } from '../consts';
---

<footer class="footer">
  <div class="section-shell footer-inner">
    <div>
      <span class="footer-name">Shadow</span>
      <p class="footer-copy">Encrypted real-time coding for any editor, with a smoother handoff than screen share.</p>
    </div>
    <div class="footer-links">
      <a
        href={marketplaceUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="footer"
        data-cta-target="vscode_marketplace"
        data-cta-surface="website"
      >
        VS Code
      </a>
      <span class="sep">&middot;</span>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="footer"
        data-cta-target="github"
        data-cta-surface="website"
      >
        GitHub
      </a>
      <span class="sep">&middot;</span>
      <span>MIT License</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 1.8rem 1.6rem 2.2rem;
  }

  .footer-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .footer-name {
    display: block;
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--text);
    margin-bottom: 0.35rem;
  }

  .footer-copy {
    max-width: 29rem;
    color: var(--text-secondary);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-links a {
    color: var(--text-secondary);
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--text); }

  .sep { color: var(--border-strong); }

  @media (max-width: 720px) {
    .footer-inner {
      flex-direction: column;
    }
  }
</style>
