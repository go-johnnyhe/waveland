---
import { installCmd, marketplaceUrl } from '../consts';
---

<section class="hero">
  <div class="section-shell hero-inner">
    <div class="hero-copy">
      <span class="eyebrow-chip reveal">Real-time. Encrypted. Your editor.</span>
      <p class="hero-label reveal r-d1">Pair in your own tools. No screen share.</p>

      <h1 class="hero-title reveal r-d2">
        Share once.<br />
        Pair in <em>your own editor.</em>
      </h1>

      <p class="hero-desc reveal r-d3">
        One command to share. End-to-end encrypted. No accounts. Your teammate uses whatever
        editor they already have.
      </p>

      <div class="hero-actions reveal r-d4">
        <button
          type="button"
          class="primary-button"
          data-cta
          data-cta-source="hero"
          data-cta-target="cli"
          data-cta-surface="website"
          data-copy-text={installCmd}
          data-copy-source="hero"
          data-copy-target="cli"
          data-copy-surface="website"
          aria-label="Copy Shadow CLI install command"
        >
          <span data-copy-label>Copy install command</span>
        </button>

        <a
          href={marketplaceUrl}
          class="secondary-button"
          target="_blank"
          rel="noopener noreferrer"
          data-cta
          data-cta-source="hero"
          data-cta-target="vscode_marketplace"
          data-cta-surface="website"
        >
          Install VS Code extension
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(6.5rem, 15vw, 12rem);
    padding-bottom: clamp(4rem, 10vw, 8rem);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 52rem;
  }

  .hero-label {
    margin: 1.5rem 0 0;
    font-size: 1.1rem;
    color: var(--text-secondary);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6.5vw, 5.5rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin: 1.5rem 0;
    color: var(--text);
  }

  .hero-title em {
    font-style: normal;
    color: var(--accent);
  }

  .hero-desc {
    font-size: 1.25rem;
    color: var(--text-secondary);
    max-width: 42rem;
    margin-bottom: 2.8rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 5.5rem;
    }

    .hero-title {
      margin-top: 1.25rem;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
      max-width: 22rem;
    }

    .hero-actions > * {
      width: 100%;
    }
  }
</style>
