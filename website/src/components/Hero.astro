---
import { dmgUrl } from '../consts';
import AppMockup from './AppMockup.astro';
---

<section class="hero">
  <div class="section-shell hero-inner">
    <div class="hero-copy">
      <h1 class="hero-title reveal r-d1">
        Screensharing &ne;<br />
        pair programming.
      </h1>

      <p class="hero-desc reveal r-d2">
        Most &ldquo;pairing&rdquo; is one person driving. The other is <strong>stuck</strong> in someone else&rsquo;s setup.
      </p>

      <p class="hero-punch reveal r-d2">
        Shadow lets both of you edit live, in your own editor.
      </p>

      <p class="hero-editors reveal r-d3">
        VS Code &middot; Neovim &middot; Vim &middot; JetBrains &middot; Zed &mdash; keep your setup.
      </p>

      <div class="hero-actions reveal r-d3">
        <a
          href={dmgUrl}
          class="primary-button"
          data-cta
          data-cta-source="hero"
          data-cta-target="download_mac"
          data-cta-surface="website"
        >
          Download for Mac
        </a>

        <span class="hero-muted">
          Requires macOS 13+. Also available as a <a href="#install" class="muted-link">CLI</a>.
        </span>
      </div>
    </div>

    <div class="hero-mockup reveal r-d3">
      <AppMockup />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(8rem, 18vh, 16rem);
    padding-bottom: clamp(5rem, 12vh, 10rem);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 4rem;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-mockup {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: var(--text);
  }

  .hero-desc {
    font-size: 1.25rem;
    line-height: 1.7;
    margin-top: 2rem;
    max-width: 38rem;
    color: var(--text-secondary);
  }

  .hero-desc strong {
    color: var(--text);
    font-weight: 600;
  }

  .hero-punch {
    font-size: 1.25rem;
    line-height: 1.7;
    margin-top: 0.5rem;
    max-width: 38rem;
    color: var(--text);
    font-weight: 500;
  }

  .hero-editors {
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    margin-top: 3rem;
  }

  .hero-muted {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .muted-link {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .muted-link:hover {
    color: var(--text);
    opacity: 1;
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-mockup {
      justify-content: flex-start;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 5.5rem;
      padding-bottom: 4rem;
    }

    .hero-title {
      font-size: clamp(2.2rem, 9vw, 2.8rem);
    }

    .hero-desc {
      font-size: 1.1rem;
    }
  }
</style>
