---
const rows = [
  { label: 'Editor freedom', shadow: 'Any editor (Vim, VS Code, JetBrains)', liveshare: 'VS Code only', screen: 'View-only for others' },
  { label: 'Share step', shadow: 'Copy & paste one link', liveshare: 'Invite via Microsoft auth', screen: 'Send meeting link' },
  { label: 'Both people can edit', shadow: 'Yes', liveshare: 'Yes', screen: 'No' },
  { label: 'Latency', shadow: 'Near-zero (direct file sync)', liveshare: 'Low', screen: 'High (video encoding)' },
  { label: 'Privacy', shadow: 'End-to-End Encrypted', liveshare: 'Relayed via Microsoft', screen: 'Varies by provider' },
];
---

<section class="comparison">
  <div class="section-shell comparison-inner">
    <div class="comparison-copy reveal">
      <p class="section-kicker">Why Shadow</p>
      <h2 class="section-title">Built for shipping, not just watching.</h2>
      <p class="section-lead">
        Screensharing is great for presentations, but terrible for actual coding. Shadow syncs the files themselves, so you both have full control without giving up your personalized setups.
      </p>
    </div>

    <div class="table-wrap reveal r-d1">
      <table>
        <thead>
          <tr>
            <th class="col-label"></th>
            <th class="col-shadow">Shadow</th>
            <th class="col-other">Live Share</th>
            <th class="col-other">Screenshare</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class="col-label">{r.label}</td>
              <td class="col-shadow">{r.shadow}</td>
              <td class="col-other">{r.liveshare}</td>
              <td class="col-other">{r.screen}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison {
    margin-bottom: var(--gap);
  }

  .comparison-copy {
    text-align: left;
    margin-bottom: 3rem;
    max-width: 48rem;
  }

  .table-wrap {
    overflow-x: auto;
    padding-bottom: 2rem;
  }

  table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 1rem;
    min-width: 760px;
  }

  th, td {
    padding: 1.5rem;
    text-align: left;
    vertical-align: top;
  }

  th {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }

  td {
    color: var(--text-secondary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  tbody tr {
    transition: background 0.2s ease;
  }

  tbody tr:hover td {
    background: rgba(255, 255, 255, 0.01);
  }

  .col-label {
    font-weight: 500;
    color: var(--text);
    width: 20%;
  }

  .col-other {
    width: 25%;
    color: var(--text-muted);
  }

  th.col-shadow {
    color: var(--accent);
    font-weight: 600;
    width: 30%;
  }

  td.col-shadow {
    color: var(--text);
    font-weight: 500;
    background: rgba(34, 211, 170, 0.02);
  }

  tbody tr:hover td.col-shadow {
    background: rgba(34, 211, 170, 0.04);
  }

  /* Round corners for the shadow column */
  th.col-shadow {
    border-top-left-radius: 0.75rem;
    border-top-right-radius: 0.75rem;
  }
  tbody tr:last-child td.col-shadow {
    border-bottom-left-radius: 0.75rem;
    border-bottom-right-radius: 0.75rem;
  }

  @media (max-width: 768px) {
    th, td {
      padding: 1.25rem 1rem;
      font-size: 0.9rem;
    }
  }
</style>
