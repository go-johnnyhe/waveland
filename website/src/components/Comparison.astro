---
const rows = [
  { label: 'Editor freedom', shadow: 'CLI or VS Code, any editor underneath', liveshare: 'VS Code only', screen: 'Any editor, but view-only for others' },
  { label: 'Share step', shadow: 'Host copies the join command once', liveshare: 'Invite from VS Code', screen: 'Send a meeting link' },
  { label: 'Both people can edit', shadow: 'Yes', liveshare: 'Yes', screen: 'No' },
  { label: 'Latency', shadow: 'Live filesystem sync over WebSocket', liveshare: 'Low', screen: 'High' },
  { label: 'Encryption model', shadow: 'E2E key lives in the URL fragment', liveshare: 'Microsoft relay', screen: 'Depends on the call tool' },
];
---

<section class="comparison">
  <div class="section-shell comparison-inner">
    <div class="comparison-copy reveal">
      <p class="section-kicker">Why this wins</p>
      <h2 class="section-title">Better than screensharing when you actually need to ship.</h2>
      <p class="section-lead">
        Shadow is for moments when one person should not have to drive and the other should not
        have to switch editors. That is the gap between “collaboration” and “watching someone else type.”
      </p>
    </div>

    <div class="table-wrap reveal r-d1">
      <table>
        <thead>
          <tr>
            <th class="col-label"></th>
            <th class="col-shadow">Shadow</th>
            <th class="col-other">Live Share</th>
            <th class="col-other">Screenshare</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class="col-label">{r.label}</td>
              <td class="col-shadow">{r.shadow}</td>
              <td class="col-other">{r.liveshare}</td>
              <td class="col-other">{r.screen}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison {
    margin-bottom: var(--gap);
  }

  .comparison-copy {
    margin-bottom: 2rem;
  }

  .table-wrap {
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    overflow: hidden;
    background: var(--paper);
    box-shadow: var(--shadow-lg);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    min-width: 580px;
  }

  .table-wrap {
    overflow-x: auto;
  }

  thead tr {
    border-bottom: 1px solid var(--border);
  }

  th {
    text-align: left;
    padding: 1rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  td {
    padding: 1rem 1.2rem;
    border-top: 1px solid var(--border);
    color: var(--text-secondary);
    vertical-align: top;
  }

  tbody tr:first-child td { border-top: none; }

  tbody tr {
    transition: background 0.2s;
  }
  tbody tr:hover {
    background: rgba(255, 248, 240, 0.9);
  }

  .col-label {
    font-weight: 500;
    color: var(--text);
    width: 25%;
  }

  .col-other {
    width: 20%;
    color: var(--text-muted);
  }

  th.col-shadow {
    color: var(--accent);
    font-weight: 600;
    width: 28%;
  }

  td.col-shadow {
    color: var(--text);
    font-weight: 500;
    background: rgba(207, 94, 28, 0.08);
  }

  @media (max-width: 640px) {
    th, td {
      padding: 0.7rem 1rem;
      font-size: 0.8rem;
    }
  }
</style>
