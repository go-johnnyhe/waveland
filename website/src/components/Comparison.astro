---
const rows = [
  { label: 'Editor freedom', shadow: 'CLI or VS Code, any editor underneath', liveshare: 'VS Code only', screen: 'Any editor, but view-only for others' },
  { label: 'Share step', shadow: 'Host copies the join command once', liveshare: 'Invite from VS Code', screen: 'Send a meeting link' },
  { label: 'Both people can edit', shadow: 'Yes', liveshare: 'Yes', screen: 'No' },
  { label: 'Latency', shadow: 'Live filesystem sync over WebSocket', liveshare: 'Low', screen: 'High' },
  { label: 'Encryption model', shadow: 'E2E key lives in the URL fragment', liveshare: 'Microsoft relay', screen: 'Depends on the call tool' },
];
---

<section class="comparison">
  <div class="section-shell comparison-inner">
    <div class="comparison-copy reveal">
      <p class="section-kicker">Why Shadow</p>
      <h2 class="section-title">Better than screensharing when you actually need to ship.</h2>
      <p class="section-lead">
        Shadow is for moments when one person should not have to drive and the other should not
        have to switch editors. That is the gap between “collaboration” and “watching someone else type.”
      </p>
    </div>

    <div class="table-wrap reveal r-d1">
      <table>
        <thead>
          <tr>
            <th class="col-label"></th>
            <th class="col-shadow">Shadow</th>
            <th class="col-other">Live Share</th>
            <th class="col-other">Screenshare</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class="col-label">{r.label}</td>
              <td class="col-shadow">{r.shadow}</td>
              <td class="col-other">{r.liveshare}</td>
              <td class="col-other">{r.screen}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison {
    margin-bottom: var(--gap);
  }

  .comparison-copy {
    text-align: center;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .table-wrap {
    overflow-x: auto;
    padding-bottom: 2rem;
  }

  table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 1rem;
    min-width: 760px;
  }

  th, td {
    padding: 1.5rem;
    text-align: left;
    vertical-align: top;
  }

  th {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }

  td {
    color: var(--text-secondary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  tbody tr {
    transition: background 0.2s ease;
  }

  tbody tr:hover td {
    background: rgba(255, 255, 255, 0.01);
  }

  .col-label {
    font-weight: 500;
    color: var(--text);
    width: 20%;
  }

  .col-other {
    width: 25%;
    color: var(--text-muted);
  }

  th.col-shadow {
    color: var(--accent);
    font-weight: 600;
    width: 30%;
  }

  td.col-shadow {
    color: var(--text);
    font-weight: 500;
    background: rgba(34, 211, 170, 0.02);
  }

  tbody tr:hover td.col-shadow {
    background: rgba(34, 211, 170, 0.04);
  }

  /* Round corners for the shadow column */
  th.col-shadow {
    border-top-left-radius: 0.75rem;
    border-top-right-radius: 0.75rem;
  }
  tbody tr:last-child td.col-shadow {
    border-bottom-left-radius: 0.75rem;
    border-bottom-right-radius: 0.75rem;
  }

  @media (max-width: 768px) {
    th, td {
      padding: 1.25rem 1rem;
      font-size: 0.9rem;
    }
  }
</style>
