---
import { githubUrl, installCmd, marketplaceUrl } from '../consts';
---

<section class="cta">
  <div class="section-shell cta-inner reveal">
    <p class="section-kicker">Get started</p>
    <h2 class="section-title">Copy. Paste. You're paired.</h2>
    <p class="cta-lead">
      Install once, start a session, and share the join command. Shadow handles the rest.
    </p>

    <div class="cta-actions reveal r-d1">
      <button
        type="button"
        class="primary-button"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="cli"
        data-cta-surface="website"
        data-copy-text={installCmd}
        data-copy-source="final_cta"
        data-copy-target="cli"
        data-copy-surface="website"
      >
        <span data-copy-label>Copy install command</span>
      </button>

      <a
        href={marketplaceUrl}
        class="secondary-button"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="vscode_marketplace"
        data-cta-surface="website"
      >
        Install VS Code extension
      </a>

      <a
        href={githubUrl}
        class="ghost-button"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="github"
        data-cta-surface="website"
      >
        View on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    margin-bottom: calc(var(--gap) * 1.2);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cta-lead {
    max-width: 36rem;
    margin: 1.25rem 0 3rem;
    color: var(--text-secondary);
    font-size: 1.15rem;
    line-height: 1.6;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .cta-actions {
      flex-direction: column;
      width: 100%;
      max-width: 22rem;
    }

    .cta-actions > * {
      width: 100%;
    }
  }
</style>
