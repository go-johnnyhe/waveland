---
import { githubUrl, installCmd, marketplaceUrl } from '../consts';
---

<section class="cta">
  <div class="section-shell cta-inner reveal">
    <p class="section-kicker">Launch-ready flow</p>
    <h2 class="section-title">Start the session. Shadow handles the awkward part.</h2>
    <p class="cta-lead">
      The join string needs to be long because it carries the E2E key. That should not make the
      experience feel clunky. Shadow copies the full command, and the extension keeps it visible.
    </p>

    <div class="steps reveal r-d1">
      <article class="step">
        <span class="step-n">01</span>
        <h3>Install from the path you want</h3>
        <p>Copy the CLI install or grab the VS Code extension from the Marketplace.</p>
      </article>
      <article class="step">
        <span class="step-n">02</span>
        <h3>Start a session</h3>
        <p>Run `shadow start .` or use the extension, then let Shadow place the join command on your clipboard.</p>
      </article>
      <article class="step">
        <span class="step-n">03</span>
        <h3>Pair in your own tools</h3>
        <p>Your teammate pastes the command into the CLI or extension and starts editing live.</p>
      </article>
    </div>

    <div class="cta-actions reveal r-d2">
      <button
        type="button"
        class="primary-button"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="cli"
        data-cta-surface="website"
        data-copy-text={installCmd}
        data-copy-source="final_cta"
        data-copy-target="cli"
        data-copy-surface="website"
      >
        <span data-copy-label>Copy CLI install</span>
      </button>

      <a
        href={marketplaceUrl}
        class="ghost-button"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="vscode_marketplace"
        data-cta-surface="website"
      >
        Install VS Code extension
      </a>

      <a
        href={githubUrl}
        class="ghost-button"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="github"
        data-cta-surface="website"
      >
        View on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    margin-bottom: calc(var(--gap) * 0.9);
  }

  .cta-inner {
    padding: 2rem;
    border-radius: 2rem;
    background:
      linear-gradient(180deg, rgba(18, 22, 29, 0.98), rgba(24, 29, 40, 0.96));
    color: #f8f1e8;
    box-shadow: var(--shadow-xl);
  }

  .cta-inner :global(.section-kicker),
  .cta-inner :global(.section-title) {
    color: #f8f1e8;
  }

  .cta-lead {
    max-width: 42rem;
    margin: 1.2rem 0 1.8rem;
    color: rgba(248, 241, 232, 0.74);
    font-size: 1rem;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.8rem;
  }

  .step {
    padding: 1.2rem;
    border-radius: 1.3rem;
    border: 1px solid rgba(248, 241, 232, 0.1);
    background: rgba(255, 255, 255, 0.06);
  }

  .step-n {
    display: inline-block;
    margin-bottom: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgba(248, 241, 232, 0.52);
    letter-spacing: 0.12em;
  }

  .step h3 {
    font-size: 1.05rem;
    margin-bottom: 0.45rem;
  }

  .step p {
    color: rgba(248, 241, 232, 0.74);
    line-height: 1.6;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .cta-actions :global(.ghost-button) {
    border-color: rgba(248, 241, 232, 0.16);
    background: rgba(255, 255, 255, 0.06);
    color: #f8f1e8;
  }

  @media (max-width: 860px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .cta-inner {
      padding: 1.4rem;
    }

    .cta-actions {
      flex-direction: column;
    }
  }
</style>
