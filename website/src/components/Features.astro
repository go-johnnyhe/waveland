---
import { installCmd, marketplaceUrl } from '../consts';

const features = [
  {
    title: 'Any editor under the hood',
    desc: 'Shadow syncs the project itself, so one person can stay in Vim while the other joins from VS Code or JetBrains.',
  },
  {
    title: 'The long link is doing real work',
    desc: 'It carries the E2E key in the URL fragment. That is why it looks long, and why the relay never gets the secret.',
  },
  {
    title: 'The workflow feels native',
    desc: 'Hosts get the full join command copied automatically, and the VS Code extension keeps the session controls visible.',
  },
];
---

<section class="features">
  <div class="section-shell features-inner">
    <div class="feature-intro reveal">
      <p class="section-kicker">CLI or VS Code</p>
      <h2 class="section-title">One session. Two ways in.</h2>
      <p class="section-lead">
        Lead with the path that matches the person in front of you. CLI for zero ceremony.
        VS Code for people who want a native panel and fewer terminal steps.
      </p>
    </div>

    <div class="bento-grid">
      <article class="bento-card cli reveal r-d1">
        <span class="path-label">For any editor</span>
        <h3>CLI install</h3>
        <p>
          Best when you want the fastest path to a live session. Install once, run `shadow`, and
          keep using the editor you already love.
        </p>
        <div class="code-wrap">
          <code>{installCmd}</code>
          <button
            type="button"
            class="primary-button"
            data-cta
            data-cta-source="install_paths"
            data-cta-target="cli"
            data-cta-surface="website"
            data-copy-text={installCmd}
            data-copy-source="install_paths"
            data-copy-target="cli"
            data-copy-surface="website"
          >
            <span data-copy-label>Copy</span>
          </button>
        </div>
      </article>

      <article class="bento-card vscode reveal r-d2">
        <span class="path-label">For VS Code users</span>
        <h3>Extension install</h3>
        <p>
          Start, join, retry, and copy the share command from the Activity Bar. Great for teammates
          who want the product to feel native immediately.
        </p>
        <a
          href={marketplaceUrl}
          class="ghost-button"
          target="_blank"
          rel="noopener noreferrer"
          data-cta
          data-cta-source="install_paths"
          data-cta-target="vscode_marketplace"
          data-cta-surface="website"
        >
          Open VS Code Marketplace
        </a>
      </article>

      {features.map((f, i) => (
        <article class={`bento-feature reveal r-d${i + 1}`}>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    margin-bottom: var(--gap);
  }

  .feature-intro {
    text-align: center;
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .bento-card,
  .bento-feature {
    background: rgba(255, 255, 255, 0.02);
    border-radius: 1.5rem;
    padding: 3rem;
  }

  .bento-card {
    grid-column: span 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .vscode {
    grid-column: span 1;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.04));
  }

  .cli {
    background: linear-gradient(135deg, rgba(34, 211, 170, 0.05), rgba(255, 255, 255, 0.02));
  }

  .bento-feature {
    grid-column: span 1;
    padding: 2.5rem;
  }

  .bento-card h3 {
    font-size: 2rem;
    font-family: var(--font-display);
    line-height: 1.1;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .bento-card p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 28rem;
  }

  .code-wrap {
    display: flex;
    gap: 1rem;
    width: 100%;
    max-width: 32rem;
  }

  .code-wrap code {
    flex: 1;
    padding: 0.95rem 1.25rem;
    border-radius: 0.5rem;
    background: var(--paper-strong);
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    color: var(--text);
  }

  .path-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 1rem;
    display: block;
  }

  .feature-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .feature-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 960px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
    
    .bento-card, .bento-feature {
      grid-column: span 1;
      padding: 2rem;
    }

    .code-wrap {
      flex-direction: column;
    }
  }
</style>
